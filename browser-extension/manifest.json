{
  "manifest_version": 3,
  "name": "KewuToolbox Browser Bridge",
  "version": "0.3.0",
  "description": "Sync browser domains to KewuToolbox (domain-level only).",
  "permissions": [
    "tabs",
    "alarms"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "KewuToolbox Bridge",
    "default_popup": "popup.html"
  }
}

                                            SelectedDate="{Binding AnalyticsDateLocal}"
                                            Margin="8,0,0,0" />
                                <Button Grid.Column="4"
                                        Content="后一天"
                                        Command="{Binding NextAnalyticsDateCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Margin="8,0,0,0"
                                        Padding="10,4" />
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="340" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,8,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="进程性质映射"
                                               FontWeight="Bold"
                                               Foreground="#0F172A"
                                               Margin="0,0,0,8" />
                                    <DataGrid Grid.Row="1"
                                              ItemsSource="{Binding ProcessCategoryItems}"
                                              AutoGenerateColumns="False"
                                              IsReadOnly="False"
                                              CanUserAddRows="False">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="进程" Binding="{Binding ProcessName}" Width="*" IsReadOnly="True" />
                                            <DataGridTemplateColumn Header="性质" Width="130">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <ComboBox ItemsSource="{Binding DataContext.CategoryOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                  SelectedItem="{Binding Category, UpdateSourceTrigger=PropertyChanged}" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>

                            <Grid Grid.Column="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="2*" />
                                    <RowDefinition Height="2*" />
                                    <RowDefinition Height="2*" />
                                    <RowDefinition Height="3*" />
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Style="{StaticResource CardStyle}">
                                    <oxy:PlotView Model="{Binding PieChartModel}" />
                                </Border>

                                <Border Grid.Row="1" Style="{StaticResource CardStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="时间范围" VerticalAlignment="Center" Margin="0,0,8,0" />
                                        <TextBox Grid.Column="1" Text="{Binding TimelineStartText, UpdateSourceTrigger=PropertyChanged}" Width="140" Margin="0,0,8,0" />
                                        <TextBox Grid.Column="2" Text="{Binding TimelineEndText, UpdateSourceTrigger=PropertyChanged}" Width="140" Margin="0,0,8,0" />
                                        <Button Grid.Column="3" Content="应用" Command="{Binding ApplyTimelineRangeCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0" />
                                        <ComboBox Grid.Column="4" ItemsSource="{Binding HeatmapMetricOptions}" SelectedItem="{Binding SelectedHeatmapMetric}" Width="140" Margin="0,0,8,0" />
                                    </Grid>
                                </Border>

                                <Border Grid.Row="2" Style="{StaticResource CardStyle}">
                                    <oxy:PlotView Model="{Binding HeatmapChartModel}" />
                                </Border>

                                <Border Grid.Row="3" Style="{StaticResource CardStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <oxy:PlotView Grid.Row="0" Model="{Binding BarChartModel}" />

                                        <DataGrid Grid.Row="1"
                                                  Margin="0,8,0,0"
                                                  ItemsSource="{Binding TimelineEntries}"
                                                  AutoGenerateColumns="False"
                                                  IsReadOnly="True">
                                            <DataGrid.Columns>
                                                <DataGridTemplateColumn Header="" Width="36">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Marker}"
                                                                       Foreground="{Binding MarkerColorHex}"
                                                                       HorizontalAlignment="Center"
                                                                       FontSize="14" />
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTextColumn Header="开始" Binding="{Binding TimeLocalText}" Width="170" />
                                                <DataGridTextColumn Header="结束" Binding="{Binding EndTimeLocalText}" Width="170" />
                                                <DataGridTextColumn Header="内容" Binding="{Binding Label}" Width="*" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem>
                    <Grid Margin="4">
                        <TextBlock Text="全部窗口开启时长"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="#0F172A"
                                   Margin="0,0,0,10" />

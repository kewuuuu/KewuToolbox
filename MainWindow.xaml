                                  ItemsSource="{Binding AllWindowStats}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  GridLinesVisibility="Horizontal">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="进程" Binding="{Binding ProcessName}" Width="140" />
                                <DataGridTextColumn Header="窗口标题" Binding="{Binding Title}" Width="*" />
                                <DataGridTextColumn Header="开启时长" Binding="{Binding TotalDurationText}" Width="140" />
                                <DataGridTextColumn Header="焦点时长" Binding="{Binding FocusDurationText}" Width="140" />
                                <DataGridTextColumn Header="最后出现" Binding="{Binding LastSeenLocalText}" Width="170" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <TabItem>
                    <Grid Margin="4">
                        <TextBlock Text="焦点窗口时长排行"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="#0F172A"
                                   Margin="0,0,0,10" />

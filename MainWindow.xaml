                                <DataGridTextColumn Header="详情" Binding="{Binding Detail}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <TabItem>
                    <Grid Margin="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="3*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,10,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="2*" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Margin="0,0,0,10">
                                <TextBlock Text="待办事项" FontSize="20" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,8" />
                                <Button Content="新建待办"
                                        Command="{Binding ToggleCreateTodoPanelCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        HorizontalAlignment="Left"
                                        Padding="14,4"
                                        Margin="0,0,0,8" />

                                <Expander Header="创建设置"
                                          IsExpanded="{Binding IsCreateTodoPanelExpanded}">
                                    <StackPanel Margin="0,6,0,0">
                                        <TextBlock Text="标题" />
                                        <TextBox Text="{Binding DraftTitle, UpdateSourceTrigger=PropertyChanged}" ToolTip="请输入任务标题" />

                                        <Grid Margin="0,8,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                                <TextBlock Text="任务类型" />
                                                <ComboBox ItemsSource="{Binding TaskTypeOptions}" SelectedItem="{Binding DraftTaskType}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                                <TextBlock Text="重复规则" />
                                                <ComboBox ItemsSource="{Binding RepeatModeOptions}" SelectedItem="{Binding DraftRepeatMode}" />
                                            </StackPanel>
                                        </Grid>

                                        <TextBlock Text="每周执行日（1-7）"
                                                   Margin="0,8,0,4"
                                                   Visibility="{Binding IsDraftWeekly, Converter={StaticResource BoolToVisibilityConverter}}" />
                                        <ItemsControl ItemsSource="{Binding DraftWeeklyDays}"
                                                      Visibility="{Binding IsDraftWeekly, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <CheckBox Content="{Binding Label}" IsChecked="{Binding IsSelected}" Margin="0,0,8,4" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <TextBlock Text="每月执行日（1-31）"
                                                   Margin="0,8,0,4"
                                                   Visibility="{Binding IsDraftMonthly, Converter={StaticResource BoolToVisibilityConverter}}" />
                                        <ItemsControl ItemsSource="{Binding DraftMonthlyDays}"
                                                      Visibility="{Binding IsDraftMonthly, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <CheckBox Content="{Binding Label}" IsChecked="{Binding IsSelected}" Margin="0,0,8,4" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <TextBlock Text="自定义模式"
                                                   Margin="0,8,0,0"
                                                   Visibility="{Binding IsDraftCustom, Converter={StaticResource BoolToVisibilityConverter}}" />
                                        <TextBox Text="{Binding DraftCustomPattern, UpdateSourceTrigger=PropertyChanged}"
                                                 Visibility="{Binding IsDraftCustom, Converter={StaticResource BoolToVisibilityConverter}}" />

                                        <CheckBox Content="开启提醒"
                                                  IsChecked="{Binding DraftReminderEnabled}"
                                                  Margin="0,8,0,4" />
                                        <UniformGrid Columns="6" IsEnabled="{Binding DraftReminderEnabled}">
                                            <TextBox Text="{Binding DraftReminderYear, UpdateSourceTrigger=PropertyChanged}" ToolTip="年（可留空）" Margin="0,0,6,0" />
                                            <TextBox Text="{Binding DraftReminderMonth, UpdateSourceTrigger=PropertyChanged}" ToolTip="月（可留空）" Margin="0,0,6,0" />
                                            <TextBox Text="{Binding DraftReminderDay, UpdateSourceTrigger=PropertyChanged}" ToolTip="日（可留空）" Margin="0,0,6,0" />
                                            <TextBox Text="{Binding DraftReminderHour, UpdateSourceTrigger=PropertyChanged}" ToolTip="时（必填 0-23）" Margin="0,0,6,0" />
                                            <TextBox Text="{Binding DraftReminderMinute, UpdateSourceTrigger=PropertyChanged}" ToolTip="分（必填 0-59）" Margin="0,0,6,0" />
                                            <TextBox Text="{Binding DraftReminderSecond, UpdateSourceTrigger=PropertyChanged}" ToolTip="秒（必填 0-59）" />
                                        </UniformGrid>

                                        <WrapPanel Margin="0,6,0,0" IsEnabled="{Binding DraftReminderEnabled}">
                                            <Button Content="年+" Style="{StaticResource StepperButtonStyle}" Command="{Binding AdjustDraftReminderValueCommand}" CommandParameter="year:1" Margin="0,0,6,0" />
                                            <Button Content="年-" Style="{StaticResource StepperButtonStyle}" Command="{Binding AdjustDraftReminderValueCommand}" CommandParameter="year:-1" Margin="0,0,8,0" />
                                            <Button Content="月+" Style="{StaticResource StepperButtonStyle}" Command="{Binding AdjustDraftReminderValueCommand}" CommandParameter="month:1" Margin="0,0,6,0" />
                                            <Button Content="月-" Style="{StaticResource StepperButtonStyle}" Command="{Binding AdjustDraftReminderValueCommand}" CommandParameter="month:-1" Margin="0,0,8,0" />
                                            <Button Content="日+" Style="{StaticResource StepperButtonStyle}" Command="{Binding AdjustDraftReminderValueCommand}" CommandParameter="day:1" Margin="0,0,6,0" />
                                            <Button Content="日-" Style="{StaticResource StepperButtonStyle}" Command="{Binding AdjustDraftReminderValueCommand}" CommandParameter="day:-1" Margin="0,0,8,0" />
                                            <Button Content="时+" Style="{StaticResource StepperButtonStyle}" Command="{Binding AdjustDraftReminderValueCommand}" CommandParameter="hour:1" Margin="0,0,6,0" />
                                            <Button Content="时-" Style="{StaticResource StepperButtonStyle}" Command="{Binding AdjustDraftReminderValueCommand}" CommandParameter="hour:-1" Margin="0,0,8,0" />
                                            <Button Content="分+" Style="{StaticResource StepperButtonStyle}" Command="{Binding AdjustDraftReminderValueCommand}" CommandParameter="minute:1" Margin="0,0,6,0" />
                                            <Button Content="分-" Style="{StaticResource StepperButtonStyle}" Command="{Binding AdjustDraftReminderValueCommand}" CommandParameter="minute:-1" Margin="0,0,8,0" />
                                            <Button Content="秒+" Style="{StaticResource StepperButtonStyle}" Command="{Binding AdjustDraftReminderValueCommand}" CommandParameter="second:1" Margin="0,0,6,0" />
                                            <Button Content="秒-" Style="{StaticResource StepperButtonStyle}" Command="{Binding AdjustDraftReminderValueCommand}" CommandParameter="second:-1" />
                                        </WrapPanel>

                                        <Button Content="创建"
                                                Command="{Binding CreateTodoCommand}"
                                                Style="{StaticResource PrimaryButtonStyle}"
                                                HorizontalAlignment="Right"
                                                Margin="0,8,0,0"
                                                Padding="14,4" />
                                    </StackPanel>
                                </Expander>
                            </StackPanel>

                            <ListBox Grid.Row="1"
                                     ItemsSource="{Binding ActiveTodoTasks}"
                                     SelectedItem="{Binding SelectedActiveTask}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="0,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <CheckBox Grid.Column="0"
                                                          Command="{Binding DataContext.CompleteTodoCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          CommandParameter="{Binding}"
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,8,0" />
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding Title}" FontWeight="Bold" VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding SummaryText}" Foreground="#64748B" />
                                                    <TextBlock Text="{Binding UpdatedAtLocalText}" Foreground="#94A3B8" FontSize="11" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <Border Grid.Row="2" BorderBrush="#E2E8F0" BorderThickness="1,1,1,0" Margin="0,8,0,0" Padding="8">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="归档列表" FontWeight="Bold" Margin="0,0,0,8" />
                                    <ListBox Grid.Row="1"
                                             ItemsSource="{Binding ArchivedTodoGroups}"
                                             SelectedItem="{Binding SelectedArchiveGroup}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="0,6">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                                        <TextBlock Text="{Binding CompletedCount, StringFormat=完成次数：{0}}" Foreground="#64748B" />
                                                        <TextBlock Text="{Binding LastCompletedAtLocalText}" Foreground="#94A3B8" FontSize="11" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                            </Border>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="10,0,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           Text="{Binding TodoStatusText}"
                                           Foreground="#475569"
                                           Margin="0,0,0,8" />

                                <Grid Grid.Row="1"
                                      Visibility="{Binding HasSelectedActiveTask, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">

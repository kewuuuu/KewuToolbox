                                  ItemsSource="{Binding FocusWindowStats}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  GridLinesVisibility="Horizontal">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="进程" Binding="{Binding ProcessName}" Width="160" />
                                <DataGridTextColumn Header="窗口标题" Binding="{Binding Title}" Width="*" />
                                <DataGridTextColumn Header="焦点时长" Binding="{Binding FocusDurationText}" Width="160" />
                                <DataGridTextColumn Header="开启时长" Binding="{Binding TotalDurationText}" Width="160" />
                                <DataGridTextColumn Header="最后出现" Binding="{Binding LastSeenLocalText}" Width="170" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <TabItem>
                    <Grid Margin="4">
                        <TextBlock Text="开关机与会话事件"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="#0F172A"
                                   Margin="0,0,0,10" />

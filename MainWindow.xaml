                                                <TextBox Text="{Binding EditReminderMinute, UpdateSourceTrigger=PropertyChanged}" ToolTip="分（必填 0-59）" Margin="0,0,6,0" />
                                                <TextBox Text="{Binding EditReminderSecond, UpdateSourceTrigger=PropertyChanged}" ToolTip="秒（必填 0-59）" />

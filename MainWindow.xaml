                                                    <DataTemplate><CheckBox Content="{Binding Label}" IsChecked="{Binding IsSelected}" Margin="0,0,8,4" /></DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <TextBlock Text="每月执行日（1-31）"
                                                       Margin="0,8,0,4"
                                                       Visibility="{Binding IsEditMonthly, Converter={StaticResource BoolToVisibilityConverter}}" />
                                            <ItemsControl ItemsSource="{Binding EditMonthlyDays}"

                                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                                    <TextBlock Text="重复规则" />
                                                    <ComboBox ItemsSource="{Binding RepeatModeOptions}" SelectedItem="{Binding EditRepeatMode}" />
                                                </StackPanel>
                                            </Grid>


                                                <Button Content="日-" Style="{StaticResource StepperButtonStyle}" Command="{Binding AdjustEditReminderValueCommand}" CommandParameter="day:-1" Margin="0,0,8,0" />
                                                <Button Content="时+" Style="{StaticResource StepperButtonStyle}" Command="{Binding AdjustEditReminderValueCommand}" CommandParameter="hour:1" Margin="0,0,6,0" />
                                                <Button Content="时-" Style="{StaticResource StepperButtonStyle}" Command="{Binding AdjustEditReminderValueCommand}" CommandParameter="hour:-1" Margin="0,0,8,0" />
                                                <Button Content="分+" Style="{StaticResource StepperButtonStyle}" Command="{Binding AdjustEditReminderValueCommand}" CommandParameter="minute:1" Margin="0,0,6,0" />
                                                <Button Content="分-" Style="{StaticResource StepperButtonStyle}" Command="{Binding AdjustEditReminderValueCommand}" CommandParameter="minute:-1" Margin="0,0,8,0" />
                                                <Button Content="秒+" Style="{StaticResource StepperButtonStyle}" Command="{Binding AdjustEditReminderValueCommand}" CommandParameter="second:1" Margin="0,0,6,0" />
                                                <Button Content="秒-" Style="{StaticResource StepperButtonStyle}" Command="{Binding AdjustEditReminderValueCommand}" CommandParameter="second:-1" />
                                            </WrapPanel>

                                            <TextBlock Text="心得（自动保存）" Margin="0,8,0,4" />
                                            <TextBox Text="{Binding EditInsight, UpdateSourceTrigger=PropertyChanged}"
                                                     TextWrapping="Wrap"
                                                     AcceptsReturn="True"
                                                     VerticalScrollBarVisibility="Auto"
                                                     MinHeight="220" />
                                        </StackPanel>
                                    </ScrollViewer>
                                </Grid>

                                <Grid Grid.Row="1"
                                      Visibility="{Binding HasSelectedArchiveGroup, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="归档详情"
                                               FontSize="20"
                                               FontWeight="Bold"
                                               Margin="0,0,0,8" />
                                    <DataGrid Grid.Row="1"
                                              ItemsSource="{Binding SelectedArchiveRecords}"
                                              AutoGenerateColumns="False"
                                              IsReadOnly="True">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="完成时间" Binding="{Binding CompletedAtLocalText}" Width="180" />
                                            <DataGridTextColumn Header="心得" Binding="{Binding Insight}" Width="*" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>

                                <Grid Grid.Row="2" Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding TodoStatusText}"
                                               Foreground="#475569"
                                               VerticalAlignment="Center" />
                                    <Button Grid.Column="1"
                                            Content="保存任务设置"
                                            Command="{Binding SaveSelectedTodoCommand}"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Padding="14,6"
                                            Margin="8,0,8,0" />
                                    <Button Grid.Column="2"
                                            Content="删除选中归档"
                                            Command="{Binding DeleteArchiveGroupCommand}"
                                            CommandParameter="{Binding SelectedArchiveGroup}"
                                            Style="{StaticResource DangerButtonStyle}"
                                            Padding="14,6" />
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>
        </Border>
    </Grid>
</Window>

                                                <Button Content="年-" Style="{StaticResource StepperButtonStyle}" Command="{Binding AdjustEditReminderValueCommand}" CommandParameter="year:-1" Margin="0,0,8,0" />
                                                <Button Content="月+" Style="{StaticResource StepperButtonStyle}" Command="{Binding AdjustEditReminderValueCommand}" CommandParameter="month:1" Margin="0,0,6,0" />

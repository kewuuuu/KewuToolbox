                                                                        Command="{Binding DataContext.StartEditFocusItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding}"
                                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                                        Margin="0,0,8,0" />
